// Pro-curo Licence Server — Prisma Schema
// Database: PostgreSQL 16
// Reference: Technical Architecture Document, Section 6

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// Customer organisation records
// ─────────────────────────────────────────────
model Customer {
  id              String          @id @default(uuid())
  customerNumber  String          @unique // Auto-generated: PCSCN-YYYYMMDD-0001
  name            String
  contactEmail    String
  contactPhone    String?         // Primary contact telephone number
  primaryContact  String?         // Primary contact person's name
  deploymentModel DeploymentModel
  notes           String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  licences Licence[]

  @@map("customers")
}

enum DeploymentModel {
  SAAS       // Model A — Hosted by Pro-curo Software
  HYBRID     // Model B — Customer-hosted, Pro-curo-managed
  ON_PREMISES // Model C — Customer-managed
}

// ─────────────────────────────────────────────
// Licence entitlements
// ─────────────────────────────────────────────
model Licence {
  id               String          @id @default(uuid())
  customerId       String
  licenceKey       String          @unique // Stored as bcrypt hash in production
  licenceType      LicenceType     @default(PER_USER) // PER_USER or CONCURRENT
  licensedUsers    Int             // For PER_USER: max active user accounts; for CONCURRENT: max simultaneous sessions
  expiryDate       DateTime
  status           LicenceStatus   @default(ACTIVE)
  deploymentModel  DeploymentModel // Copied from customer at creation time
  gracePeriodDays  Int             @default(30) // Days the instance can run without reaching the licence server
  invoiceReference String?         // FreeAgent invoice number for original licence purchase
  createdBy        String          // Admin user ID who issued this licence
  notes            String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  customer     Customer           @relation(fields: [customerId], references: [id])
  instances    Instance[]
  offlineFiles OfflineFile[]
  amendments   LicenceAmendment[]

  @@index([customerId])
  @@index([status])
  @@map("licences")
}

// ─────────────────────────────────────────────
// Licence amendments — tracks user count changes, renewals, etc.
// Each amendment records the change and the FreeAgent invoice reference
// ─────────────────────────────────────────────
model LicenceAmendment {
  id                String        @id @default(uuid())
  licenceId         String
  amendmentType     AmendmentType
  previousUsers     Int           // User count before change
  newUsers          Int           // User count after change
  previousType      LicenceType?  // Only set for TYPE_CHANGE amendments
  newType           LicenceType?  // Only set for TYPE_CHANGE amendments
  invoiceReference  String?       // FreeAgent invoice number for this amendment
  notes             String?
  createdBy         String        // Admin user ID who made this amendment
  createdAt         DateTime      @default(now())

  licence Licence @relation(fields: [licenceId], references: [id])

  @@index([licenceId])
  @@map("licence_amendments")
}

enum AmendmentType {
  USER_INCREASE    // Customer purchased additional user licences
  USER_DECREASE    // Customer reduced user count (e.g. contract change)
  RENEWAL          // Licence renewed (new invoice, possibly new expiry)
  EXPIRY_EXTENSION // Expiry date extended
  TYPE_CHANGE      // Licence type changed (e.g. CONCURRENT → PER_USER)
}

enum LicenceStatus {
  ACTIVE
  SUSPENDED
  EXPIRED
  REVOKED
}

enum LicenceType {
  PER_USER    // Each user account consumes a licence slot — total active users <= licensedUsers
  CONCURRENT  // Simultaneous sessions are limited — active sessions <= licensedUsers
}

// ─────────────────────────────────────────────
// Registered Pro-curo V5 instances
// ─────────────────────────────────────────────
model Instance {
  id              String    @id @default(uuid())
  licenceId       String
  instanceUuid    String    @unique // UUID generated by the V5 instance
  softwareVersion String?
  lastCheckIn     DateTime?
  activeUsers     Int       @default(0)
  ipAddress       String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  licence  Licence   @relation(fields: [licenceId], references: [id])
  checkIns CheckIn[]

  @@index([licenceId])
  @@index([lastCheckIn])
  @@map("instances")
}

// ─────────────────────────────────────────────
// Check-in audit log
// ─────────────────────────────────────────────
model CheckIn {
  id              String        @id @default(uuid())
  instanceId      String
  timestamp       DateTime      @default(now())
  activeUsers     Int
  softwareVersion String
  responseStatus  CheckInStatus
  ipAddress       String?
  rawPayload      Json?         // Stored for debugging/audit; stripped in production

  instance Instance @relation(fields: [instanceId], references: [id])

  @@index([instanceId])
  @@index([timestamp])
  @@map("check_ins")
}

enum CheckInStatus {
  VALID
  WARNING
  EXPIRED
  INVALID
}

// ─────────────────────────────────────────────
// Generated offline licence files
// ─────────────────────────────────────────────
model OfflineFile {
  id          String   @id @default(uuid())
  licenceId   String
  issuedAt    DateTime @default(now())
  expiresAt   DateTime
  generatedBy String   // Admin user ID
  fileHash    String   // SHA-256 hash of the generated file

  licence Licence @relation(fields: [licenceId], references: [id])

  @@index([licenceId])
  @@map("offline_files")
}

// ─────────────────────────────────────────────
// Admin portal audit log
// ─────────────────────────────────────────────
model AuditLog {
  id         String   @id @default(uuid())
  userId     String
  action     String   // e.g. "licence.create", "licence.revoke", "customer.update"
  targetType String   // e.g. "licence", "customer", "instance"
  targetId   String
  details    Json?    // Additional context about the action
  timestamp  DateTime @default(now())

  user AdminUser @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([timestamp])
  @@index([targetType, targetId])
  @@map("audit_log")
}

// ─────────────────────────────────────────────
// Admin portal users (Pro-curo engineers)
// ─────────────────────────────────────────────
model AdminUser {
  id          String    @id @default(uuid())
  azureAdId   String?   @unique // Azure AD object ID for SSO (null in dev mode)
  email       String    @unique
  displayName String
  role        AdminRole @default(ENGINEER)
  lastLogin   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  auditLogs AuditLog[]

  @@map("admin_users")
}

enum AdminRole {
  ADMIN
  ENGINEER
  READ_ONLY
}
