// Pro-curo Licence Server — Prisma Schema
// Database: PostgreSQL 16
// Reference: Technical Architecture Document, Section 6

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// Customer organisation records
// ─────────────────────────────────────────────
model Customer {
  id              String          @id @default(uuid())
  customerNumber  String          @unique // Auto-generated: PCSCN-YYYYMMDD-0001
  name            String
  contactEmail    String
  contactPhone    String?         // Primary contact telephone number
  primaryContact  String?         // Primary contact person's name
  deploymentModel DeploymentModel
  notes           String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  licences    Licence[]
  deployments Deployment[]

  @@map("customers")
}

enum DeploymentModel {
  SAAS       // Model A — Hosted by Pro-curo Software
  HYBRID     // Model B — Customer-hosted, Pro-curo-managed
  ON_PREMISES // Model C — Customer-managed
}

// ─────────────────────────────────────────────
// Customer deployment configurations
// ─────────────────────────────────────────────
model Deployment {
  id                String           @id @default(uuid())
  customerId        String
  deploymentLabel   String           // Friendly name, e.g. "ACME Corp Production"
  status            DeploymentStatus @default(PROVISIONING)

  // Application configuration — Backend container
  containerAppName  String?          // Azure Container App name, e.g. "procuro-acme-backend"
  containerAppUrl   String?          // Full URL, e.g. "https://procuro-acme-backend.grayriver-3c973afe.uksouth.azurecontainerapps.io"
  // Application configuration — Frontend container
  frontendAppName   String?          // Azure Container App name, e.g. "procuro-acme-frontend"
  frontendAppUrl    String?          // Full URL, e.g. "https://procuro-acme-frontend.grayriver-3c973afe.uksouth.azurecontainerapps.io"
  imageTag          String?          // Current deployed ACR image tag, e.g. "build25"
  v5BuildId         String?          // Pro-curo V5 application build ID, e.g. "PCSv5-20260326-1925-25"
  customDomain      String?          // Custom domain — points to frontend container
  sslCertExpiry     DateTime?        // SSL certificate expiry date

  // Database configuration
  databaseType      DatabaseType     @default(POSTGRESQL)
  databaseHost      String?          // Hostname or IP
  databasePort      Int?             // Port number
  databaseName      String?          // Database/schema name
  connectivityType  ConnectivityType? // How we connect to customer DB

  // Metadata
  notes             String?
  provisionedBy     String           // Admin user ID
  provisionedAt     DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  customer Customer @relation(fields: [customerId], references: [id])
  configs  TenantConfig[]

  @@unique([containerAppName])
  @@unique([frontendAppName])
  @@unique([customDomain])
  @@unique([databaseName, databaseHost])
  @@index([customerId])
  @@index([status])
  @@map("deployments")
}

// ─────────────────────────────────────────────
// Per-deployment tenant configuration (key-value store)
// ─────────────────────────────────────────────
model TenantConfig {
  id            String   @id @default(uuid())
  deploymentId  String
  category      String   // e.g. "env_var", "feature_flag", "domain", "notification"
  configKey     String   // e.g. "DATABASE_URL", "CUSTOM_DOMAIN", "ENABLE_AUDIT_EXPORT"
  configValue   String   // The value (encrypted values prefixed with "enc:")
  isSecret      Boolean  @default(false) // If true, value is masked in the UI
  description   String?  // Human-readable description of what this config does
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  deployment Deployment @relation(fields: [deploymentId], references: [id])

  @@unique([deploymentId, configKey])
  @@index([deploymentId])
  @@index([category])
  @@map("tenant_configs")
}

enum DeploymentStatus {
  PROVISIONING  // Being set up
  ACTIVE        // Live and operational
  SUSPENDED     // Temporarily disabled
  DECOMMISSIONED // No longer in use
}

enum DatabaseType {
  POSTGRESQL
  SQLSERVER
  MYSQL
  MARIADB
}

enum ConnectivityType {
  PRIVATE_LINK
  SITE_TO_SITE_VPN
  EXPRESSROUTE
  PUBLIC_ENDPOINT
}

// ─────────────────────────────────────────────
// Licence entitlements
// ─────────────────────────────────────────────
model Licence {
  id               String          @id @default(uuid())
  customerId       String
  licenceKey       String          @unique // Stored as bcrypt hash in production
  licenceType      LicenceType     @default(PER_USER) // PER_USER or CONCURRENT
  licensedUsers    Int             // For PER_USER: max active user accounts; for CONCURRENT: max simultaneous sessions
  expiryDate       DateTime
  status           LicenceStatus   @default(ACTIVE)
  deploymentModel  DeploymentModel // Copied from customer at creation time
  gracePeriodDays  Int             @default(30) // Days the instance can run without reaching the licence server
  invoiceReference String?         // FreeAgent invoice number for original licence purchase
  createdBy        String          // Admin user ID who issued this licence
  notes            String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  customer     Customer           @relation(fields: [customerId], references: [id])
  instances    Instance[]
  offlineFiles OfflineFile[]
  amendments   LicenceAmendment[]

  @@index([customerId])
  @@index([status])
  @@map("licences")
}

// ─────────────────────────────────────────────
// Licence amendments — tracks user count changes, renewals, etc.
// Each amendment records the change and the FreeAgent invoice reference
// ─────────────────────────────────────────────
model LicenceAmendment {
  id                String        @id @default(uuid())
  licenceId         String
  amendmentType     AmendmentType
  previousUsers     Int           // User count before change
  newUsers          Int           // User count after change
  previousType      LicenceType?  // Only set for TYPE_CHANGE amendments
  newType           LicenceType?  // Only set for TYPE_CHANGE amendments
  invoiceReference  String?       // FreeAgent invoice number for this amendment
  notes             String?
  createdBy         String        // Admin user ID who made this amendment
  createdAt         DateTime      @default(now())

  licence Licence @relation(fields: [licenceId], references: [id])

  @@index([licenceId])
  @@map("licence_amendments")
}

enum AmendmentType {
  USER_INCREASE    // Customer purchased additional user licences
  USER_DECREASE    // Customer reduced user count (e.g. contract change)
  RENEWAL          // Licence renewed (new invoice, possibly new expiry)
  EXPIRY_EXTENSION // Expiry date extended
  TYPE_CHANGE      // Licence type changed (e.g. CONCURRENT → PER_USER)
}

enum LicenceStatus {
  ACTIVE
  SUSPENDED
  EXPIRED
  REVOKED
}

enum LicenceType {
  PER_USER    // Each user account consumes a licence slot — total active users <= licensedUsers
  CONCURRENT  // Simultaneous sessions are limited — active sessions <= licensedUsers
}

// ─────────────────────────────────────────────
// Registered Pro-curo V5 instances
// ─────────────────────────────────────────────
model Instance {
  id              String    @id @default(uuid())
  licenceId       String
  instanceUuid    String    @unique // UUID generated by the V5 instance
  softwareVersion String?
  lastCheckIn     DateTime?
  activeUsers     Int       @default(0)
  ipAddress       String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  licence  Licence   @relation(fields: [licenceId], references: [id])
  checkIns CheckIn[]

  @@index([licenceId])
  @@index([lastCheckIn])
  @@map("instances")
}

// ─────────────────────────────────────────────
// Check-in audit log
// ─────────────────────────────────────────────
model CheckIn {
  id              String        @id @default(uuid())
  instanceId      String
  timestamp       DateTime      @default(now())
  activeUsers     Int
  softwareVersion String
  responseStatus  CheckInStatus
  ipAddress       String?
  rawPayload      Json?         // Stored for debugging/audit; stripped in production

  instance Instance @relation(fields: [instanceId], references: [id])

  @@index([instanceId])
  @@index([timestamp])
  @@map("check_ins")
}

enum CheckInStatus {
  VALID
  WARNING
  EXPIRED
  INVALID
}

// ─────────────────────────────────────────────
// Generated offline licence files
// ─────────────────────────────────────────────
model OfflineFile {
  id          String   @id @default(uuid())
  licenceId   String
  issuedAt    DateTime @default(now())
  expiresAt   DateTime
  generatedBy String   // Admin user ID
  fileHash    String   // SHA-256 hash of the generated file

  licence Licence @relation(fields: [licenceId], references: [id])

  @@index([licenceId])
  @@map("offline_files")
}

// ─────────────────────────────────────────────
// Admin portal audit log
// ─────────────────────────────────────────────
model AuditLog {
  id         String   @id @default(uuid())
  userId     String
  action     String   // e.g. "licence.create", "licence.revoke", "customer.update"
  targetType String   // e.g. "licence", "customer", "instance"
  targetId   String
  details    Json?    // Additional context about the action
  timestamp  DateTime @default(now())

  user AdminUser @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([timestamp])
  @@index([targetType, targetId])
  @@map("audit_log")
}

// ─────────────────────────────────────────────
// Admin portal users (Pro-curo engineers)
// ─────────────────────────────────────────────
model AdminUser {
  id          String    @id @default(uuid())
  azureAdId   String?   @unique // Azure AD object ID for SSO (null in dev mode)
  email       String    @unique
  passwordHash String?   // Bcrypt hash for production authentication (null in dev mode)
  displayName String
  role        AdminRole @default(ENGINEER)
  lastLogin   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  auditLogs AuditLog[]

  @@map("admin_users")
}

enum AdminRole {
  ADMIN
  ENGINEER
  READ_ONLY
}
