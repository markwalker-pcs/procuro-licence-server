# Pro-curo Licence Server — Environment Variables
# Copy this file to .env and fill in the values

# Database
DATABASE_URL="postgresql://procuro_licence:password@localhost:5433/procuro_licence?schema=public"

# Server
PORT=3100
NODE_ENV=development

# JWT (for Admin Portal sessions)
JWT_SECRET=change-me-to-a-secure-random-string
JWT_EXPIRY=8h

# CORS
CORS_ORIGIN=http://localhost:5174

# Ed25519 Key Paths (for offline licence file signing)
# In production, the private key is stored in Azure Key Vault
ED25519_PRIVATE_KEY_PATH=./keys/private.pem
ED25519_PUBLIC_KEY_PATH=./keys/public.pem

# HMAC Shared Secret (for check-in payload validation)
# Each customer instance has its own shared secret, but this is the server-side master
HMAC_SECRET=change-me-to-a-secure-random-string

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=debug
